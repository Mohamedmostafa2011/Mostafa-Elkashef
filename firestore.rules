rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is approved
    function isApproved() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // --- COLLECTION: COURSES ---
    match /courses/{courseId} {
      allow read: if true; // Anyone can see available courses for signup/login
      allow write: if isAdmin();
    }

    // --- COLLECTION: USERS ---
    match /users/{userId} {
      // Users can see and update their own profiles
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Admins can see and manage everyone
      allow read, write: if isAdmin();
      // Allow signup (creating initial user doc)
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // --- COLLECTION: COURSE_CONTENT ---
    match /course_content/{itemId} {
      // Admins have full access
      allow read, write: if isAdmin();
      
      // Approved students can read non-hidden content belonging to their courses
      allow read: if isApproved() && 
        resource.data.isHidden == false;
    }
  }
}
